#!/usr/bin/env python3

from __future__ import annotations

import logging
import sys
import tempfile
from collections import defaultdict

import dnf

logging.basicConfig(format='[%(levelname)s] %(message)s', level=logging.DEBUG)

# https://github.com/rpm-software-management/libdnf/issues/1757
# Workaround cannot work, as not all files are exposed as Provides, it
# would require to fill the provides_map will all files of the distro.
WORKAROUND_LIBDNF_BUG = False

V = '10.0'
SECTIONS = ['BaseOS', 'AppStream', 'CRB', 'devel']
CONFS = ('src', 'bin')

dbs = {}

def next_or_none(it):
    try:
        return next(it)
    except StopIteration:
        return None

# FIXME won't work if p2 has several occurrences
def prefer(lst, p1_name, p2_name):
    p2 = next_or_none(p for p in lst if p.name == p2_name)
    if p2:
        p1 = next_or_none(p for p in lst if p.name == p1_name)
        if p1:
            lst.remove(p2)

def write_recipe(pkg: dnf.package.Package) -> None:
    pkgname = f"{pkg.name}-{pkg.version}-{pkg.release}.src.rpm"
    rpms: list[dnf.package.Package] = list(dbs['bin'].sack.query().filter(sourcerpm=f"{pkgname}"))
    fname = f"{pkg.name}_{f'{pkg.epoch}:' if pkg.epoch else ''}{pkg.version}-{pkg.release}.bb"
    with open(f"meta-almalinux/recipes-alma10/{fname}", "w") as r:
        print(f'''
inherit dnf-bridge

PN = "{pkg.name}"
PE = "{pkg.epoch}"
PV = "{pkg.version}"
PR = "{pkg.release}"
PACKAGES = "{' '.join(p.name for p in rpms)}"
''', file=r)

        logging.debug("%s: %s", pkgname, rpms)
        print(f'\nURI_src = "{pkg.remote_location(schemes=["https", "http", "file"])};unpack=0"',
              file=r)
        print(f'SRC_URI += "${{URI_src}}"', file=r)

        for p in rpms:
            logging.debug(" *  %s", p)
            print(f'\nURI_{p.name} = "{p.remote_location(schemes=["https", "http", "file"])};unpack=0"',
                  file=r)
            # FIXME: checksum
            print(f'SRC_URI += "${{URI_{p.name}}}"', file=r)

            rel: hawkey.Reldep
            requires: set[dnf.package.Package] = set()
            for rel in p.requires:
                if WORKAROUND_LIBDNF_BUG:
                    providers = provides_map.get(rel.name, [])
                else:
                    providers = list(dbs['bin'].sack.query().filter(provides=rel).filter(latest=1))

                logging.debug("'%s' : %s", rel, providers)

                # FIXME should really generate virtual alternatives instead
                if not(providers):
                    logging.warning("%s: %s: no providers for '%s'", pkg.name, p.name, rel)
                    continue

                if len(providers) > 1:
                    prefer(providers, 'coreutils', 'coreutils-single')
                    prefer(providers, 'util-linux', 'util-linux-core')
                    prefer(providers, 'cronie-noanacron', 'cronie-anacron')
                    prefer(providers, 'libcurl', 'libcurl-minimal')
                    prefer(providers, 'google-noto-sans-balinese-fonts', 'google-noto-serif-balinese-fonts')
                    prefer(providers, 'google-noto-sans-myanmar-vf-fonts', 'google-noto-serif-myanmar-vf-fonts')
                    prefer(providers, 'libverto-libev', 'libverto-libevent')
                    prefer(providers, 'kernel-debug-core', 'kernel-debug-uki-virt')
                    prefer(providers, 'kernel-core', 'kernel-uki-virt')
                    prefer(providers, 'gdb-headless', 'gdb-minimal')
                    prefer(providers, 'systemtap-client', 'systemtap-devel')
                    prefer(providers, 'SDL2', 'sdl2-compat')
                    prefer(providers, 'glibc-langpack-en', 'glibc-all-langpacks')
                    prefer(providers, 'ant-unbound', 'ant-openjdk21')
                    prefer(providers, 'ocaml-runtime', 'ocaml')
                    prefer(providers, 'nfs-utils', 'nfsv4-client-utils')
                    prefer(providers, 'tomcat-lib', 'tomcat9-lib')
                    prefer(providers, 'nodejs', 'nodejs22')
                    prefer(providers, 'systemd', 'rsyslog')
                    prefer(providers, 'pinentry-gnome3', 'pinentry-qt')
                    prefer(providers, 'elinks', 'lynx')
                    prefer(providers, 'ocaml-ordering', 'ocaml-ordering-devel')
                    prefer(providers, 'ocaml-dyn', 'ocaml-dyn-devel')
                    prefer(providers, 'ocaml-stdune', 'ocaml-stdune-devel')
                    prefer(providers, 'ocaml-xdg', 'ocaml-xdg-devel')
                    prefer(providers, 'ocaml-dune-glob', 'ocaml-dune-glob-devel')
                    prefer(providers, 'ocaml-dune-rpc', 'ocaml-dune-rpc-devel')
                    prefer(providers, 'ocaml-dune-private-libs', 'ocaml-dune-private-libs-devel')
                    prefer(providers, 'ocaml-fileutils', 'ocaml-fileutils-devel')
                    prefer(providers, 'curl', 'wget')
                    prefer(providers, 'redhat-display-fonts', 'redhat-display-vf-fonts')
                    prefer(providers, 'redhat-text-fonts', 'redhat-text-vf-fonts')
                    prefer(providers, 'google-noto-sans-fonts', 'google-noto-sans-vf-fonts')
                    prefer(providers, 'pipewire-pulseaudio', 'pulseaudio-module-bluetooth')
                    prefer(providers, 'nodejs-libs', 'nodejs22-libs')
                    prefer(providers, 'texlive-ragged2e', 'texlive-ms')
                    prefer(providers, 'texlive-latex', 'texlive-collection-latexrecommended')
                    prefer(providers, 'texlive-everyshi', 'texlive-ms')
                    prefer(providers, 'texlive-count1to', 'texlive-ms')
                    prefer(providers, 'tomcat-el-3.0-api', 'tomcat9-el-3.0-api')

                    # WTF!?
                    prefer(providers, 'libtiff', 'golang-tests') # libtiffxx.so.6()(64bit)
                    prefer(providers, 'kernel-modules-extra', 'kernel-debug-modules-extra')
                    prefer(providers, 'sblim-sfcb', 'tog-pegasus') # cim-server

                    # (weston or cage or kwin-wayland or mutter or gnome-kiosk)
                    prefer(providers, 'gnome-kiosk', 'mutter')

                    #prefer(providers, 'emacs', 'emacs-lucid', 'emacs-nw', 'emacs-gtk+x11')
                    if rel.name == 'emacs(bin)':
                        providers = [p for p in providers if p.name == 'emacs']

                    if rel.name == 'opencryptoki(token)':
                        providers = [p for p in providers if p.name == 'opencryptoki-swtok']

                    if rel.name == 'glibc-langpack':
                        providers = [p for p in providers if p.name == 'glibc-minimal-langpack']

                    if rel.name == 'selinux-policy-any':
                        providers = [p for p in providers if p.name == 'selinux-policy-minimum']

                    if rel.name == 'lorax-templates':
                        providers = [p for p in providers if p.name == 'lorax-templates-generic']

                    if rel.name == 'maven-jdk-binding':
                        providers = [p for p in providers if p.name == 'maven-unbound']

                    if str(rel) == 'mvn(org.apache.tomcat:tomcat-servlet-api) = 9.0.87':
                        providers = [p for p in providers if p.name == 'tomcat-servlet-4.0-api']

                    if str(rel) == 'mvn(org.apache.tomcat:tomcat-servlet-api)':
                        providers = [p for p in providers if p.name == 'tomcat-servlet-4.0-api']

                    if str(rel) == 'mvn(org.apache.tomcat:tomcat-jsp-api) = 9.0.87':
                        providers = [p for p in providers if p.name == 'tomcat-jsp-2.3-api']

                    if rel.name == 'kernel':
                        providers = [p for p in providers if p.name == 'kernel']

                    # packages appearing in several locations
                    # there should be already only 1 evr per package name, but be safe
                    providers = list(dict( ((p.name, p.evr), p) for p in providers).values())

                assert len(providers) == 1, f"too many providers for {rel}: {[str(p) for p in providers]} {tuple(p.name for p in providers)}"

                requires.add(providers[0])

            # FIXME: this assumes there is no "more recent provider"
            # for those packages, that would not match the reldep
            rdeps = f" \\\n {' \\\n '.join(p.name for p in requires)} \\\n" if requires else ""
            print(f'RDEPENDS:{p.name} = "{rdeps}"', file=r)
            print(f'RDEPENDS += "${{RDEPENDS:{p.name}}}"', file=r)

cachedirs = {}

with (tempfile.TemporaryDirectory() as persistdir,
      tempfile.TemporaryDirectory() as reposdir,
      tempfile.TemporaryDirectory() as cachedirs['src'],
      tempfile.TemporaryDirectory() as cachedirs['bin'],
      tempfile.TemporaryDirectory() as varsdir):
    # avoid any system configuration
    for i in CONFS:
        conf = dnf.conf.Conf()

        conf_config_file_path = conf._config.config_file_path()
        conf_config_file_path.set(value='/dev/null', priority=conf_config_file_path.getPriority())
        conf_reposdir = conf._config.reposdir()
        conf_reposdir.set(conf_reposdir.getPriority(), reposdir)
        conf_persistdir = conf._config.persistdir()
        conf_persistdir.set(conf_persistdir.getPriority(), persistdir)
        conf_system_cachedir = conf._config.system_cachedir()
        conf_system_cachedir.set(conf_system_cachedir.getPriority(), cachedirs[i])
        conf_varsdir = conf._config.varsdir()
        conf_varsdir.set(conf_varsdir.getPriority(), varsdir)

        # necessary to solve deps against concrete files
        conf._config.optional_metadata_types().getValue().push_back('load_filelists')

        dbs[i] = dnf.Base(conf=conf)

    for section in SECTIONS:
        dbs['bin'].repos.add_new_repo(section, conf, [f"https://vault.almalinux.org/{V}/{section}/x86_64_v2/os/"])
        dbs['src'].repos.add_new_repo(f"{section}-src", conf, [f"https://vault.almalinux.org/{V}/{section}/Source/"])
    dbs['bin'].fill_sack(load_system_repo=False)
    dbs['src'].fill_sack(load_system_repo=False)

    rpms_src: list[dnf.package.Package] = list(dbs['src'].sack.query().filter(latest=1).available())
    print(f"#src={len(rpms_src)}")

    if WORKAROUND_LIBDNF_BUG:
        # Work around libdnf bug: the provides filter does not work on
        # non-RPM platforms. Build a provides-to- package map manually
        # instead.
        _USRMOVE_PREFIXES = ('/bin/', '/sbin/')
        provides_map: dict[str, list[dnf.package.Package]] = defaultdict(list)
        for p in dbs['bin'].sack.query().available():
            for prov in p.provides:
                provides_map[prov.name].append(p)
                # Index file provides under UsrMove-canonical paths too
                prov_name = prov.name
                if prov_name.startswith(_USRMOVE_PREFIXES):
                    provides_map['/usr' + prov_name].append(p)

    for pkg in rpms_src:
        if len(sys.argv) > 1 and pkg.name not in sys.argv[1:]:
            continue
        write_recipe(pkg)
