#!/usr/bin/env python3

from __future__ import annotations

import logging
import tempfile
from collections import defaultdict

import dnf

logging.basicConfig(format='[%(levelname)s] %(message)s', level=logging.WARNING)

# https://github.com/rpm-software-management/libdnf/issues/1757
# Workaround cannot work, as not all files are exposed as Provides, it
# would require to fill the provides_map will all files of the distro.
WORKAROUND_LIBDNF_BUG = False

V = '10.0'
SECTIONS = ['BaseOS', 'AppStream', 'CRB', 'devel']
CONFS = ('src', 'bin')

cachedirs = {}
dbs = {}

def str_reldep(rel: hawkey.Reldep) -> str:
    return f"{rel.name} ({rel.relation} {rel.version})"

def write_recipe(pkg: dnf.package.Package) -> None:
    rpms: list[dnf.package.Package] = list(dbs['bin'].sack.query().filter(sourcerpm=f"{pkg}.rpm"))
    fname = f"{pkg.name}_{f'{pkg.epoch}:' if pkg.epoch else ''}{pkg.version}-{pkg.release}.bb"
    with open(f"meta-almalinux/recipes-alma10/{fname}", "w") as r:
        print(f'''
PN = "{pkg.name}"
PE = "{pkg.epoch}"
PV = "{pkg.version}"
PR = "{pkg.release}"
PACKAGES = "{' '.join(p.name for p in rpms)}"
''', file=r)

        for p in rpms:
            print(f'\nURI_{p.name} = "{p.remote_location(schemes=["https", "http", "file"])};unpack=0"',
                  file=r)
            rel: hawkey.Reldep
            print(f'''RDEPENDS:{p.name} = "{' '.join(str_reldep(rel) for rel in p.requires)}"''',
                  file=r)
            print(f'''RPROVIDES:{p.name} = "{' '.join(str_reldep(rel) for rel in p.provides)}"''',
                  file=r)

with (tempfile.TemporaryDirectory() as persistdir,
      tempfile.TemporaryDirectory() as reposdir,
      tempfile.TemporaryDirectory() as cachedirs['src'],
      tempfile.TemporaryDirectory() as cachedirs['bin'],
      tempfile.TemporaryDirectory() as varsdir):
    # avoid any system configuration
    for i in CONFS:
        conf = dnf.conf.Conf()

        conf_config_file_path = conf._config.config_file_path()
        conf_config_file_path.set(value='/dev/null', priority=conf_config_file_path.getPriority())
        conf_reposdir = conf._config.reposdir()
        conf_reposdir.set(conf_reposdir.getPriority(), reposdir)
        conf_persistdir = conf._config.persistdir()
        conf_persistdir.set(conf_persistdir.getPriority(), persistdir)
        conf_system_cachedir = conf._config.system_cachedir()
        conf_system_cachedir.set(conf_system_cachedir.getPriority(), cachedirs[i])
        conf_varsdir = conf._config.varsdir()
        conf_varsdir.set(conf_varsdir.getPriority(), varsdir)

        # necessary to solve deps against concrete files
        conf._config.optional_metadata_types().getValue().push_back('load_filelists')

        dbs[i] = dnf.Base(conf=conf)

    for section in SECTIONS:
        dbs['bin'].repos.add_new_repo(section, conf, [f"https://vault.almalinux.org/{V}/{section}/x86_64_v2/os/"])
        dbs['src'].repos.add_new_repo(f"{section}-src", conf, [f"https://vault.almalinux.org/{V}/{section}/Source/"])
    dbs['bin'].fill_sack(load_system_repo=False)
    dbs['src'].fill_sack(load_system_repo=False)

    rpms_src: list[dnf.package.Package] = list(dbs['src'].sack.query().filter(latest=1).available())
    print(f"#src={len(rpms_src)}")

    if WORKAROUND_LIBDNF_BUG:
        # Work around libdnf bug: the provides filter does not work on
        # non-RPM platforms. Build a provides-to- package map manually
        # instead.
        _USRMOVE_PREFIXES = ('/bin/', '/sbin/')
        provides_map: dict[str, list[dnf.package.Package]] = defaultdict(list)
        for p in dbs['bin'].sack.query().available():
            for prov in p.provides:
                provides_map[prov.name].append(p)
                # Index file provides under UsrMove-canonical paths too
                prov_name = prov.name
                if prov_name.startswith(_USRMOVE_PREFIXES):
                    provides_map['/usr' + prov_name].append(p)

    for pkg in rpms_src:
        write_recipe(pkg)
